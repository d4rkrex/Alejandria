{
  "name": "memoir_search",
  "description": "Search concepts within a memoir using FTS5",
  "inputSchema": {
    "type": "object",
    "properties": {
      "memoir": {
        "type": "string",
        "description": "Memoir name (required)"
      },
      "query": {
        "type": "string",
        "description": "Search query (required)"
      },
      "limit": {
        "type": "integer",
        "description": "Maximum results (default: 10)",
        "default": 10
      }
    },
    "required": ["memoir", "query"]
  }
}
